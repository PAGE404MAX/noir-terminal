audio_block = '''# ============================ AUDIO / SAMPLER ============================

def _load_wave_stdlib(path: str):
    import wave
    with wave.open(path, 'rb') as wf:
        channels = wf.getnchannels()
        width = wf.getsampwidth()
        rate = wf.getframerate()
        nframes = wf.getnframes()
        raw = wf.readframes(nframes)
        if width == 2:
            data = np.frombuffer(raw, dtype=np.int16).astype(np.float32) / 32768.0
        elif width == 1:
            data = (np.frombuffer(raw, dtype=np.uint8).astype(np.float32) - 128) / 128.0
        elif width == 4:
            data = np.frombuffer(raw, dtype=np.int32).astype(np.float32) / 2147483648.0
        else:
            raise ValueError(f"Unsupported sample width: {width}")
        if channels > 1:
            data = data.reshape(-1, channels).mean(axis=1)
        return data, rate

def _resample_audio(data: np.ndarray, orig_sr: int, target_sr: int) -> np.ndarray:
    if orig_sr == target_sr:
        return data
    ratio = target_sr / orig_sr
    n_samples = int(len(data) * ratio)
    return np.interp(
        np.linspace(0, len(data) - 1, n_samples),
        np.arange(len(data)),
        data
    ).astype(np.float32)

try:
    import soundfile as sf
    _HAS_SOUNDFILE = True
except ImportError:
    sf = None
    _HAS_SOUNDFILE = False

def load_audio_file(path: str, target_sr: int = 44100) -> Optional[np.ndarray]:
    data = None
    rate = target_sr
    if _HAS_SOUNDFILE:
        try:
            data, rate = sf.read(path, dtype='float32')
            if data.ndim > 1:
                data = data.mean(axis=1)
        except Exception:
            data = None
    if data is None and path.lower().endswith('.wav'):
        try:
            data, rate = _load_wave_stdlib(path)
        except Exception:
            data = None
    if data is None:
        return None
    if rate != target_sr:
        data = _resample_audio(data, rate, target_sr)
    peak = np.max(np.abs(data))
    if peak > 0:
        data = data / peak * 0.8
    return data.astype(np.float32)

class SampleVoice:
    def __init__(self, buffer: np.ndarray, velocity: float = 1.0):
        self.buffer = buffer
        self.pos = 0
        self.velocity = float(velocity)

class Sampler:
    def __init__(self, sample_rate: int = 44100):
        self.sample_rate = sample_rate
        self.samples: List[np.ndarray] = []
        self._voices: List[SampleVoice] = []
        self._lock = threading.Lock()

    def add_sample(self, path: str) -> bool:
        data = load_audio_file(path, self.sample_rate)
        if data is None:
            return False
        self.samples.append(data)
        return True

    def clear_samples(self):
        with self._lock:
            self.samples.clear()
            self._voices.clear()

    def trigger(self, sample_index: int, velocity: float = 1.0):
        with self._lock:
            if 0 <= sample_index < len(self.samples):
                self._voices.append(SampleVoice(self.samples[sample_index], velocity))

    def generate_audio(self, frames: int) -> np.ndarray:
        out = np.zeros(frames, dtype=np.float32)
        with self._lock:
            dead: List[int] = []
            for i, voice in enumerate(self._voices):
                remaining = len(voice.buffer) - voice.pos
                if remaining <= 0:
                    dead.append(i)
                    continue
                to_copy = min(frames, remaining)
                out[:to_copy] += voice.buffer[voice.pos:voice.pos + to_copy] * voice.velocity
                voice.pos += to_copy
                if voice.pos >= len(voice.buffer):
                    dead.append(i)
            for i in reversed(dead):
                self._voices.pop(i)
        return out

# ============================ SYNTH ENGINE ============================
'''

