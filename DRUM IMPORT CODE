drum_machine_class = '''class DrumMachineDialog(QDialog):
    PAD_LABELS = ["C1", "C#1", "D1", "D#1", "E1", "F1", "F#1", "G1", "G#1", "A1", "A#1", "B1", "C2", "C#2", "D2", "D#2"]

    def __init__(self, parent: "Nill", pattern_index: int) -> None:
        super().__init__(parent)
        self.daw = parent
        self.pattern_index = pattern_index
        self.setWindowTitle(f"Drum Machine – {self.daw.patterns[pattern_index].name}")
        self.setMinimumSize(520, 400)
        self.pads: List[QPushButton] = []
        self.build_ui()
        self.apply_theme_style()
        self.refresh_pads()

    def build_ui(self) -> None:
        layout = QVBoxLayout(self)
        layout.setSpacing(12)
        layout.setContentsMargins(16, 16, 16, 16)

        title = QLabel(f"◈ {self.daw.patterns[self.pattern_index].name}")
        title.setStyleSheet("font-size: 16px; font-weight: bold; color: #FFF;")
        layout.addWidget(title)

        grid = QWidget()
        grid_layout = QGridLayout(grid)
        grid_layout.setSpacing(8)
        for i in range(16):
            btn = QPushButton()
            btn.setFixedSize(100, 80)
            btn.setProperty("pad_index", i)
            btn.clicked.connect(lambda checked=False, idx=i: self.trigger_pad(idx))
            grid_layout.addWidget(btn, i // 4, i % 4)
            self.pads.append(btn)

        layout.addWidget(grid)

        info = QLabel("Pads map to MIDI notes C1–D#2 (36–51). Use the Piano Roll to sequence them.")
        info.setStyleSheet("color: #888; font-size: 10px;")
        layout.addWidget(info)

        btn_close = QPushButton("Close")
        btn_close.clicked.connect(self.accept)
        layout.addWidget(btn_close)

    def refresh_pads(self) -> None:
        sampler = self.daw.samplers.get(self.pattern_index)
        for i, btn in enumerate(self.pads):
            label = self.PAD_LABELS[i]
            if sampler and i < len(sampler.samples):
                btn.setText(f"{label}\\nSample {i+1}")
                btn.setEnabled(True)
            else:
                btn.setText(f"{label}\\n—")
                btn.setEnabled(False)

    def trigger_pad(self, idx: int) -> None:
        sampler = self.daw.samplers.get(self.pattern_index)
        if sampler and idx < len(sampler.samples):
            sampler.trigger(idx, 0.9)

    def apply_theme_style(self) -> None:
        t = self.daw.theme
        self.setStyleSheet(f"""
            QDialog {{ background: {t['bg_main']}; color: {t['text_main']}; border: 1px solid {t['border']}; }}
            QLabel {{ color: {t['text_main']}; padding: 2px; }}
            QPushButton {{ background: {t['button_bg']}; border: 1px solid {t['button_border']}; color: {t['text_main']}; padding: 6px; border-radius: 4px; }}
            QPushButton:hover {{ background: {t['button_hover']}; }}
            QPushButton:disabled {{ background: {t['bg_muted']}; color: {t['text_dim']}; border: 1px solid {t['grid_sub']}; }}
        """)

    def keyPressEvent(self, event) -> None:
        key_map = {
            Qt.Key.Key_Z: 0, Qt.Key.Key_X: 1, Qt.Key.Key_C: 2, Qt.Key.Key_V: 3,
            Qt.Key.Key_A: 4, Qt.Key.Key_S: 5, Qt.Key.Key_D: 6, Qt.Key.Key_F: 7,
            Qt.Key.Key_Q: 8, Qt.Key.Key_W: 9, Qt.Key.Key_E: 10, Qt.Key.Key_R: 11,
            Qt.Key.Key_1: 12, Qt.Key.Key_2: 13, Qt.Key.Key_3: 14, Qt.Key.Key_4: 15,
        }
        idx = key_map.get(event.key())
        if idx is not None:
            self.trigger_pad(idx)
            event.accept()
            return
        super().keyPressEvent(event)

'''

