# Try to find Stereo Mix automatically
stereo_mix_keywords = ['stereo mix', 'what u hear', 'loopback', 'wave out', 'out mix', 'realtek stereo', 'virtual audio']
for i, device in enumerate(devices):
    if device['max_input_channels'] > 0:
        name_lower = device['name'].lower()
        if any(keyword in name_lower for keyword in stereo_mix_keywords):
            AUDIO_DEVICE = i
            print(f"✓ Found: [{i}] {device['name']}")
            break

