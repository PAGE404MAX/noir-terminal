visual_surface = pygame.Surface((NATIVE_W, NATIVE_H), pygame.SRCALPHA)
blur_surface = pygame.Surface((NATIVE_W, NATIVE_H), pygame.SRCALPHA)
ghost_trails = []

# Frame setup
frame_rect = pygame.Rect(15, 15, NATIVE_W - 30, NATIVE_H - 30)

